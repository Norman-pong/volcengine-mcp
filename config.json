{
  "mcpServers": {
    "volcengine-image": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/path/to/volcengine_mcp",
        "python",
        "volcengine_mcp.py"
      ],
      "env": {
        "AITOKEN_VOLCENGINE": "your-api-key-here",
        "VOLCENGINE_OUTPUT_DIR": "~/Desktop/volcengine_images"
      }
    }
  }
}